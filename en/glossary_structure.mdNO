<!-- Set document language -->
<script>
  // Set on html element immediately (this works in head)
  document.documentElement.lang = 'en';
  
  // Set on body when it exists
  (function() {
    function setBodyLang() {
      if (document.body) {
        document.body.setAttribute('data-lang', 'en');
      } else {
        setTimeout(setBodyLang, 10);
      }
    }
    setBodyLang();
  })();
</script>

<!-- Include navigation filter -->
<!-- Language-aware navigation filter - Properly handles parent pages across languages -->
<style>
  /* Hide navigation initially to prevent flicker */
  #site-nav {
    visibility: hidden;
  }
  
  #site-nav.nav-filtered {
    visibility: visible;
  }
  
  /* Keep child lists visible when they contain active items */
  .nav-list-item:has(.nav-list-link.active) > .nav-list {
    display: block !important;
  }
  
  /* Ensure active link is highlighted */
  .nav-list-link.active {
    font-weight: 600;
  }
  </style>
  
  <script>
  (function() {
    // Get current page language
    const currentLang = document.documentElement.lang || 
                        document.body.getAttribute('data-lang') || 
                        'en';
    
    function filterNavigation() {
      const siteNav = document.getElementById('site-nav');
      if (!siteNav) {
        setTimeout(filterNavigation, 50);
        return;
      }
      
      const navItems = siteNav.querySelectorAll('.nav-list-item');
      
      // Filter each navigation item
      navItems.forEach(function(navItem) {
        const link = navItem.querySelector(':scope > .nav-list-link');
        if (!link) return;
        
        const href = link.getAttribute('href');
        if (!href) return;
        
        // Extract language from URL - try multiple patterns
        let linkLang = null;
        
        // Pattern 1: /baseurl/lang/ or /lang/
        const pattern1 = href.match(/\/([a-z]{2,3})\//);
        if (pattern1) {
          linkLang = pattern1[1];
        }
        
        // Pattern 2: Check if URL ends with /lang or /lang/ (for home pages)
        const pattern2 = href.match(/\/([a-z]{2,3})\/?$/);
        if (!linkLang && pattern2) {
          linkLang = pattern2[1];
        }
        
        // If we found a language code in the URL
        if (linkLang) {
          if (linkLang !== currentLang) {
            // Hide items from other languages
            navItem.style.display = 'none';
          } else {
            // Show items from current language
            navItem.style.display = '';
          }
        } else {
          // No language in URL - could be a special page or root
          // Check if it has children with language codes
          const hasChildrenInCurrentLang = hasChildrenForLanguage(navItem, currentLang);
          
          if (hasChildrenInCurrentLang) {
            // This parent has children in current language, keep it
            navItem.style.display = '';
          } else {
            // Check if any children at all
            const childList = navItem.querySelector(':scope > .nav-list');
            if (childList) {
              const anyChildren = childList.querySelectorAll(':scope > .nav-list-item');
              if (anyChildren.length > 0) {
                // Has children but not in current language, hide it
                navItem.style.display = 'none';
              }
            }
            // If no children at all, keep visible (might be language-neutral)
          }
        }
      });
      
      // Expand active navigation path
      const activeLink = siteNav.querySelector('.nav-list-link.active');
      if (activeLink) {
        expandParents(activeLink);
      }
      
      // Show navigation
      siteNav.classList.add('nav-filtered');
    }
    
    function hasChildrenForLanguage(navItem, language) {
      const childList = navItem.querySelector(':scope > .nav-list');
      if (!childList) return false;
      
      const children = childList.querySelectorAll(':scope > .nav-list-item');
      
      for (let i = 0; i < children.length; i++) {
        const childLink = children[i].querySelector(':scope > .nav-list-link');
        if (childLink) {
          const childHref = childLink.getAttribute('href');
          if (childHref) {
            const langMatch = childHref.match(/\/([a-z]{2,3})\//);
            if (langMatch && langMatch[1] === language) {
              return true;
            }
          }
        }
      }
      
      return false;
    }
    
    function expandParents(element) {
      let current = element.closest('.nav-list-item');
      
      while (current) {
        // Make sure parent item is visible
        current.style.display = '';
        
        const parentList = current.parentElement;
        if (parentList && parentList.classList.contains('nav-list')) {
          // Show the child list
          parentList.style.display = 'block';
          
          // Move to parent item
          const parentItem = parentList.closest('.nav-list-item');
          if (parentItem) {
            current = parentItem;
          } else {
            break;
          }
        } else {
          break;
        }
      }
    }
    
    // Start immediately
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', filterNavigation);
    } else {
      filterNavigation();
    }
  })();
  </script>

<!-- Include TOC filter for parent pages -->
<!-- Filter Table of Contents by language -->
<script>
    (function() {
      // Get current page language
      const currentLang = document.documentElement.lang || 
                          document.body.getAttribute('data-lang') || 
                          'en';
      
      // Wait for DOM to be ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', filterTOC);
      } else {
        filterTOC();
      }
      
      function filterTOC() {
        // Target all content area links that might be in a TOC
        // This includes: page content, markdown TOC, child lists, etc.
        const selectors = [
          '.main-content ul li a',           // General content lists
          '.main-content ol li a',           // Ordered lists in content
          '#markdown-toc li a',              // Markdown TOC
          '.table-of-contents li a',         // Table of contents class
          'ul.child-list li a',              // Child page lists
          '.child-list li a',                // Alternative child list
          'nav#toc li a',                    // TOC navigation
          '.page-content ul:not(.nav-list) li a',  // Content lists (not nav)
          '.main-content-wrap ul li a',      // Main content wrapper lists
          '.js-main-content ul li a',        // Just-the-docs main content
          '.main ul li a'                    // Main element lists
        ];
        
        const allLinks = document.querySelectorAll(selectors.join(', '));
        
        allLinks.forEach(function(link) {
          const href = link.getAttribute('href');
          if (!href) return;
          
          // Skip anchor links (same page navigation)
          if (href.startsWith('#')) return;
          
          // Skip external links
          if (href.startsWith('http://') || href.startsWith('https://')) return;
          
          // Extract language code from URL (e.g., /caresets/nl/, /nl/, /fr/, /en/)
          // Matches pattern: /XX/ where XX is 2-3 letter language code
          // Also handles baseurl like /caresets/en/
          const langMatch = href.match(/\/([a-z]{2,3})\//);

          if (langMatch) {
            const linkLang = langMatch[1];

            // Only filter if the matched code is a known language (en, fr, nl)
            const knownLanguages = ['en', 'fr', 'nl'];
            if (knownLanguages.indexOf(linkLang) !== -1) {
              // Hide TOC/list items from other languages
              if (linkLang !== currentLang) {
                const listItem = link.closest('li');
                if (listItem) {
                  listItem.style.display = 'none';
                }
              }
            }
          }
        });
        
        // Clean up empty lists/sections after filtering
        setTimeout(function() {
          const allLists = document.querySelectorAll('.main-content ul, .main-content ol');
          allLists.forEach(function(list) {
            const visibleItems = Array.from(list.children).filter(function(child) {
              return child.style.display !== 'none' && child.offsetHeight > 0;
            });
            
            // If list is empty after filtering, hide it
            if (visibleItems.length === 0) {
              list.style.display = 'none';
            }
          });
        }, 100);
      }
    })();
    </script>




















