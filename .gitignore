# Build output / caches
/_site
/_site.zip
/__pycache__
/.jekyll-cache
Gemfile.lock

# NOTE: _resources/ is GENERATED from input/ by build_content.py. It is kept
# under version control (not ignored) so the site can be built and deployed
# without running Python when only non-input files change. The publish workflow
# regenerates and commits it whenever input/ changes — never hand-edit it.

# Auto-generated backups (created by generate_glossary.py / add_glossary_mappings.py)
*.backup.json
*.backup.csv

# Manual backup folders
/_resources/models - Copy/
# Safety copy written by `backup_content.py --restore`
/backups/_pre-restore/
