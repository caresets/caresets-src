        <svg viewBox="0 0 24 24" aria-hidden="true"><use xlink:href="#svg-arrow-right"></use></svg>
      </button><a href="/glossary/nl/related-topics/" class="nav-list-link">Related topics</a><ul class="nav-list"><li class="nav-list-item"><a href="/glossary/nl/data-models/" class="nav-list-link">Logical Data models</a></li><li class="nav-list-item"><a href="/glossary/fr/data-models/" class="nav-list-link">Logical Data models</a></li></ul></li><li class="nav-list-item"><button class="nav-list-expander btn-reset" aria-label="Related topics submenu" aria-expanded="false">
        <svg viewBox="0 0 24 24" aria-hidden="true"><use xlink:href="#svg-arrow-right"></use></svg>
      </button><a href="/glossary/fr/related-topics/" class="nav-list-link">Related topics</a><ul class="nav-list"><li class="nav-list-item"><a href="/glossary/nl/data-models/" class="nav-list-link">Logical Data models</a></li><li class="nav-list-item"><a href="/glossary/fr/data-models/" class="nav-list-link">Logical Data models</a></li></ul></li><li class="nav-list-item"><a href="/glossary/en/terminologies/" class="nav-list-link">Terminologies</a></li><li class="nav-list-item"><a href="/glossary/nl/terminologies/" class="nav-list-link">Terminologies</a></li><li class="nav-list-item"><a href="/glossary/fr/terminologies/" class="nav-list-link">Terminologies</a></li><li class="nav-list-item"><a href="/glossary/nl/about/" class="nav-list-link">About</a></li><li class="nav-list-item"><a href="/glossary/fr/about/" class="nav-list-link">About</a></li></ul>
  
</nav>


<div class="d-md-block d-none site-footer">
  
  
    <!-- Empty file to hide the "This site uses Just the Docs" message in the navigation sidebar -->
  
  </div>
</header>

  
  <div class="main" id="top">
    <div id="main-header" class="main-header">
  
    

<div class="search" role="search">
  <div class="search-input-wrap">
    <input type="text" id="search-input" class="search-input" tabindex="0" placeholder="Search BeSafeShare" autocomplete="off">
    <label for="search-input" class="search-label">
      <span class="sr-only">Search BeSafeShare</span>
      <svg viewBox="0 0 24 24" class="search-icon" aria-hidden="true"><use xlink:href="#svg-search"></use></svg>
    </label>
  </div>
